<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.control.Button?>

<VBox alignment="CENTER_LEFT" spacing="15" xmlns:fx="https://javafx.com/fxml"
      fx:controller="com.example.passwordvalidator.PasswordValidatorController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    <PasswordField fx:id="passwordText" promptText="Enter password" prefWidth="200" minWidth="200" maxWidth="200"/>
    <Label fx:id="status" text=""/>
</VBox>